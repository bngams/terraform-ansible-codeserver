# Copier en .env :  cp .env.example .env   (le .env est gitignoré)

# Domaine de base = LA ZONE Cloudflare (ex: deltavia.com), PAS un sous-domaine.
# Les postes seront servis sur lab1.DOMAIN … lab8.DOMAIN (+ labls.DOMAIN).
# /!\ schéma à 1 niveau → couvert par l'Universal SSL gratuit (*.DOMAIN).
# DNS chez Cloudflare (proxifié, orange) :  *.DOMAIN A <IP_VPS>
DOMAIN=example.com

# Token API Cloudflare pour le challenge DNS-01 (certificat origine wildcard).
# Scope : Zone > DNS > Edit, sur la zone du domaine. (My Profile > API Tokens)
CLOUDFLARE_API_TOKEN=cf-token-xxxxxxxxxxxxxxxxxxxx

# Image du sidecar DinD (par défaut : docker:27-dind).
# Pour le lab "Docker bas niveau / runc", construire l'image enrichie une fois :
#   docker build -t dind-runc:local -f dind/Dockerfile.runc dind
# puis décommenter :
# DIND_IMAGE=dind-runc:local

# Mots de passe code-server, un par stagiaire (à générer aléatoirement)
S1_PASSWORD=change-me-1
S2_PASSWORD=change-me-2
S3_PASSWORD=change-me-3
S4_PASSWORD=change-me-4
S5_PASSWORD=change-me-5
S6_PASSWORD=change-me-6
S7_PASSWORD=change-me-7
S8_PASSWORD=change-me-8
