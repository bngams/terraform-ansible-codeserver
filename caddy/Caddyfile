# Caddyfile — reverse proxy + TLS WILDCARD via Cloudflare DNS-01.
# {$DOMAIN} et {$CLOUDFLARE_API_TOKEN} viennent de l'environnement (cf. .env).
#
# Topologie : Cloudflare (proxy : DDoS/WAF, cache l'IP, TLS edge)  →  ce Caddy
# (route par sous-domaine vers les conteneurs). Le challenge DNS-01 obtient un
# certificat *.{$DOMAIN} qui fonctionne MÊME quand Cloudflare proxifie (orange).
#
# Prérequis Cloudflare :
#   - DNS proxifié (orange) :  {$DOMAIN} A <IP_VPS>  et  *.{$DOMAIN} A <IP_VPS>
#   - SSL/TLS mode : Full (strict)
#   - API token (scope Zone:DNS:Edit sur la zone) → CLOUDFLARE_API_TOKEN dans .env

# Snippet réutilisable : config TLS Cloudflare (cert wildcard via DNS-01).
(cf_tls) {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
}

# Un site par sous-domaine → son conteneur (port 8080 interne).
1.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-1:8080
}
2.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-2:8080
}
3.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-3:8080
}
4.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-4:8080
}
5.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-5:8080
}
6.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-6:8080
}
7.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-7:8080
}
8.{$DOMAIN} {
	import cf_tls
	reverse_proxy student-8:8080
}

# Console LocalStack partagée
ls.{$DOMAIN} {
	import cf_tls
	reverse_proxy localstack:4566
}

# Domaine racine (sans sous-domaine) : page d'entrée.
{$DOMAIN} {
	import cf_tls
	respond "Lab GitOps — acces stagiaires : 1.{$DOMAIN} ... 8.{$DOMAIN}"
}
