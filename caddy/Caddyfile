# Caddyfile — reverse proxy + TLS WILDCARD via Cloudflare DNS-01.
# {$DOMAIN} et {$CLOUDFLARE_API_TOKEN} viennent de l'environnement (cf. .env).
#
# Topologie : Cloudflare (proxy : DDoS/WAF, cache l'IP, TLS edge)  →  ce Caddy
# (route par sous-domaine vers les conteneurs). Le challenge DNS-01 obtient un
# certificat *.{$DOMAIN} qui fonctionne MÊME quand Cloudflare proxifie (orange).
#
# Prérequis Cloudflare :
#   - DNS proxifié (orange) :  {$DOMAIN} A <IP_VPS>  et  *.{$DOMAIN} A <IP_VPS>
#   - SSL/TLS mode : Full (strict)
#   - API token (scope Zone:DNS:Edit sur la zone) → CLOUDFLARE_API_TOKEN dans .env

# Certificat wildcard unique pour tout *.{$DOMAIN}, résolu par DNS Cloudflare.
*.{$DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}

	# Routage par sous-domaine → le bon conteneur (port 8080 interne).
	@s1 host 1.{$DOMAIN}
	handle @s1 { reverse_proxy student-1:8080 }
	@s2 host 2.{$DOMAIN}
	handle @s2 { reverse_proxy student-2:8080 }
	@s3 host 3.{$DOMAIN}
	handle @s3 { reverse_proxy student-3:8080 }
	@s4 host 4.{$DOMAIN}
	handle @s4 { reverse_proxy student-4:8080 }
	@s5 host 5.{$DOMAIN}
	handle @s5 { reverse_proxy student-5:8080 }
	@s6 host 6.{$DOMAIN}
	handle @s6 { reverse_proxy student-6:8080 }
	@s7 host 7.{$DOMAIN}
	handle @s7 { reverse_proxy student-7:8080 }
	@s8 host 8.{$DOMAIN}
	handle @s8 { reverse_proxy student-8:8080 }

	# Console LocalStack partagée
	@ls host ls.{$DOMAIN}
	handle @ls { reverse_proxy localstack:4566 }

	# Tout autre sous-domaine → message d'accueil
	handle { respond "Lab GitOps — accès : 1.{$DOMAIN} … 8.{$DOMAIN}" 200 }
}

# Domaine racine (sans sous-domaine) : page d'entrée.
{$DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
	respond "Lab GitOps — accès stagiaires : 1.{$DOMAIN} … 8.{$DOMAIN}"
}
